global:
  evaluation_interval: 30s
  scrape_interval: 30s
  external_labels:
    prometheus: default/test
    prometheus_replica: $(POD_NAME)
scrape_configs:
- job_name: scrapeConfig/default/testscrapeconfig1
  ionos_sd_config:
  - authorization:
      type: Bearer
      credentials: value
    datacenter_id: 11111111-1111-1111-1111-111111111111
    tls_config:
      ca_file: /etc/prometheus/certs/0_default_secret-ca_
      cert_file: /etc/prometheus/certs/0_default_secret-cert_
      key_file: /etc/prometheus/certs/0_default_secret_key
  relabel_configs:
  - source_labels:
    - job
    target_label: __tmp_prometheus_job_name
